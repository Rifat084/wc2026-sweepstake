rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // CHANGE THIS to your admin Gmail/email (must match Firebase Auth user)
    // Example: "you@gmail.com"
    // ============================================================
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "YOUR_ADMIN_EMAIL@example.com";
    }

    // Public can READ live standings.
    // ONLY the admin email can WRITE (add/edit matches).
    match /wc2026/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
